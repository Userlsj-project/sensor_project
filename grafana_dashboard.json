          "sql": {
            "columns": [
              { "parameters": [], "type": "function" }
            ],
            "groupBy": [{ "property": { "type": "string" }, "type": "groupBy" }],
            "limit": 50
          }
        }
      ],
      "title": "센서값 시계열 그래프",
