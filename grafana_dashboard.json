        "justifyMode": "center",
        "orientation": "auto",
        "reduceOptions": {
          "calcs": ["lastNotNull"],
          "fields": "",
          "values": false
        },
        "textMode": "auto"
      },
      "targets": [
        {
          "datasource": { "type": "mysql", "uid": "${DS_SENSOR_MYSQL}" },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT value FROM sensor_data ORDER BY id DESC LIMIT 1",
          "refId": "A"
        }
      ],
